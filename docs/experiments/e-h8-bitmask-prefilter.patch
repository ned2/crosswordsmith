 find_intersecting_word(Letters, WLen, PlacedWords, GridLen, Start, Dir) :-
+    % Prefilter (E-H8): the candidate's letter mask, computed once, gates each
+    % placed word by an O(1) integer AND. A placed word whose mask is disjoint
+    % from the candidate's shares no letter, so it can supply no crossing cell -
+    % skip it before paying the intersection/3 + list_to_set scan. Skipping only
+    % zero-candidate pairs leaves the enumeration of REAL candidates (and thus
+    % every golden) byte-identical.
+    letters_mask(Letters, CandMask),
     member(PW, PlacedWords),
+    get_dict(answer, PW, PAnswer),
+    answer_mask(PAnswer, PMask),
+    CandMask /\ PMask =\= 0,
     get_dict(letters, PW, PLetters),
     get_dict(dir, PW, PDir),
     get_dict(start, PW, PStart),
