+% inc_count: recount a word only when it can have CHANGED (shares a letter with
+% the last-placed word), else carry its cache entry forward untouched.
+%
+% E-H10 watched-witnesses short-circuit (the recount branch): before doing the
+% full rescan for a shares-letter word, re-validate its cached witnesses against
+% the CURRENT grid with check_word_fits (O(word length) each). If they still hold
+% AND the cached bucket was saturated (Count == 2), the true count is still >= 2
+% -> capped at 2 -> the SAME bucket a full recount would return, so keep the cache
+% entry and skip the rescan (see recount_or_reuse/9 for the soundness scope).
 inc_count(PrevMap, LastLetters, PlacedWords, GridLen, Start, Dir, GIn, Entry, AIn, AOut) :-
     Entry = [A|_],
     entry_letters(Entry, ELetters),
     (   shares_letter(ELetters, LastLetters)
-    ->  mrv_count(2, PlacedWords, GridLen, Start, Dir, GIn, Entry, Count)
-    ;   get_assoc(A, PrevMap, Count)            % carry forward (>= true count)
+    ->  recount_or_reuse(PrevMap, A, ELetters, PlacedWords, GridLen, Start, Dir, GIn, Entry, WC)
+    ;   get_assoc(A, PrevMap, WC)               % carry forward (>= true count)
     ->  true
-    ;   mrv_count(2, PlacedWords, GridLen, Start, Dir, GIn, Entry, Count)
+    ;   mrv_count_wit(PlacedWords, GridLen, Start, Dir, GIn, Entry, Count, Wit),
