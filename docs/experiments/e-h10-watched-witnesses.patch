     ),
-    put_assoc(A, AIn, Count, AOut).
+    put_assoc(A, AIn, WC, AOut).
+
+% recount_or_reuse/9: for a word that shares a letter with the last placement,
+% try the watched-witness short-circuit before falling back to a full recount.
+%
+% SOUNDNESS (why only the saturated bucket short-circuits): the recount trigger is
+% "shares a letter", which is EXACTLY the case where placing the last word can ADD
+% a new crossing placement (mrv_inc invariant) - so a shares-letter word's count
+% can RISE, not only fall. Hence:
+%   * Count == 2 (== cap): a rise is impossible past the cap. If both witnesses are
+%     still legal the count is still >= 2, so the bucket is unchanged -> SOUND to
+%     keep. (A full recount would also stop at 2.)
+%   * Count =< 1: a surviving witness proves >= 1 (or >= 0), but a NEW placement
+%     crossing the just-placed word could push a 1 to 2 or a 0 to 1 - the witness
+%     check cannot see it. Short-circuiting here would UNDER-count and reorder the
+%     search (non-byte-identical), so these ALWAYS do the full recount.
+% The full recount refreshes witnesses too, so the cache stays current.
+recount_or_reuse(PrevMap, A, ELetters, _PlacedWords, GridLen, _Start, _Dir, GIn, _Entry, WC) :-
+    get_assoc(A, PrevMap, wc(2, PrevWit)),
+    witnesses_valid(PrevWit, ELetters, GridLen, GIn),
+    !,
+    WC = wc(2, PrevWit).
+recount_or_reuse(_PrevMap, _A, _ELetters, PlacedWords, GridLen, Start, Dir, GIn, Entry, WC) :-
+    mrv_count_wit(PlacedWords, GridLen, Start, Dir, GIn, Entry, Count, Wit),
+    WC = wc(Count, Wit).
+
+% Every cached witness (a first-count legal placement) must STILL be legal on the
+% current grid. check_word_fits/5 is the same non-binding legality probe the count
+% uses, so a surviving witness is a genuine current placement.
+witnesses_valid([], _ELetters, _GridLen, _GIn).
+witnesses_valid([w(S, D)|Ws], ELetters, GridLen, GIn) :-
+    check_word_fits(ELetters, S, D, GridLen, GIn),
+    witnesses_valid(Ws, ELetters, GridLen, GIn).
 
