+% count_upto2_wit(:Goal, +Start, +Dir, -Count, -Witnesses): count_upto2 that ALSO
+% captures the WITNESSES for its count - the first up-to-2 legal placements found,
+% each a ground w(Start,Dir) re-checkable description (E-H10b). Start/Dir are the
+% shared placement vars the Goal binds per solution (mrv_count_goal builds Goal
+% around them); on the Nth solution we snapshot a GROUND copy of w(Start,Dir) into
+% the mutable holder via nb_setarg (a copy onto the global stack, so it survives
+% the \+ that discards the loop's bindings). The snapshot is a pure side effect
+% inside the SAME loop conjunction and the N >= 2 early exit is unchanged, so
+% enumeration order and the resulting Count are byte-identical to count_upto2/2 -
+% the witnesses are exactly the first placements in today's order. Witnesses is a
+% list of length min(Count,2). Reused verbatim from branch 92179c8 (E-H10), but
+% only ever reached from the recount fallback here.
+:- meta_predicate count_upto2_wit(0, ?, ?, -, -).
+count_upto2_wit(Goal, Start, Dir, Count, Witnesses) :-
+    Counter = wcounter(0, none, none),
+    (   \+ ( Goal,
+             arg(1, Counter, N0),
+             N is N0 + 1,
+             nb_setarg(1, Counter, N),
+             ( N =:= 1 -> nb_setarg(2, Counter, w(Start, Dir))
+             ; N =:= 2 -> nb_setarg(3, Counter, w(Start, Dir))
+             ; true ),
+             N >= 2 )
+    ->  true
+    ;   true
+    ),
+    arg(1, Counter, Count),
+    wcounter_witnesses(Counter, Witnesses).
+
+% Collect the 0-2 captured witnesses (holder args 2,3) in enumeration order,
+% dropping the `none` placeholders for counts below that arg.
+wcounter_witnesses(wcounter(_, W1, W2), Witnesses) :-
+    ( W1 == none -> Witnesses = []
+    ; W2 == none -> Witnesses = [W1]
+    ;               Witnesses = [W1, W2]
+    ).
+
 
