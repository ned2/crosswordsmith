#!/usr/bin/env swipl

:- set_prolog_flag(verbose, silent).

% crosswordsmith - the command-line interface (design-spec §5). One verb per
% capability; a bare invocation prints usage and exits non-zero. The engine
% lives in prolog/crosswordsmith/ (loaded via load.pl); this file is only argv
% plumbing + dispatch, so end-to-end behaviour is covered by the golden-output
% regression (run_tests.sh) rather than by consulting this file into the
% unit-test harness.
%
% NB: the `:- initialization(main, main)` directive is at the FOOT of this
% file, AFTER the project load below, so THIS main wins the
% main-initialization registration (last registration wins).

% Load the whole implementation via load.pl (the single owner of load order),
% resolved relative to this script so it works from any cwd.
% directory_file_path/3 is autoload-only (library(filesex)); explicit so this
% root also loads under autoload(false) (P11/C5, matching load.pl).
:- use_module(library(filesex), [directory_file_path/3]).
:- prolog_load_context(directory, Dir),
   directory_file_path(Dir, 'load.pl', LoadFile),
   ensure_loaded(LoadFile).

% Remember the script directory so the default fill dictionary resolves no
% matter the working directory.
:- prolog_load_context(directory, Dir), assertz(script_directory(Dir)).

:- use_module(library(optparse)).


main :-
    current_prolog_flag(argv, Argv),
    catch( ( cli(Argv) -> Code = 0 ; Code = 1 ),
           Error,
           ( print_message(error, Error), Code = 1 ) ),
    halt(Code).

% Verb dispatch. A failing clause -> exit 1 (main maps it). A thrown error
% (malformed input, fragment conflict, ...) propagates and is rendered by the
% error_message//1 hooks with a non-zero exit, per the spec's exit-code table.
cli([]) :- !, usage(user_error), fail.                       % AC-CLI-1: bare -> usage, non-zero
cli([H|_]) :- help_flag(H), !, usage(user_output).           % explicit --help/-h/help -> stdout, exit 0 (GNU/POSIX)
cli([Verb|Args]) :- verb(Verb), negation_flag(Args, Bad), !, % R9: reject --no-<x>
    format(user_error,
           "crosswordsmith ~w: unknown flag `~w` (boolean flags are not \c
negatable with --no-; see `crosswordsmith ~w --help`)~n", [Verb, Bad, Verb]),
    fail.
cli([arrange|Args]) :- !, arrange_cli(Args).
cli([lint|Args])    :- !, lint_cli(Args).
cli([export|Args])  :- !, export_cli(Args).
cli([fill|Args])    :- !, fill_cli(Args).
cli([Verb|_]) :-
    format(user_error, "crosswordsmith: unknown verb `~w`~n~n", [Verb]),
    usage(user_error), fail.

help_flag('--help'). help_flag('-h'). help_flag(help).

verb(arrange). verb(lint). verb(export). verb(fill).

% optparse auto-negates every boolean flag (--no-strict, --no-allow-asymmetry,
% ...), but those flag NAMES are undocumented and a footgun (--no-strict reads as
% the opposite of its actual effect), so reject any --no-<x> token up front
% (AC-CLI-2: no undocumented flag exists) - R9.
negation_flag(Args, Bad) :-
    member(Bad, Args), atom(Bad), atom_concat('--no-', _, Bad), !.

usage(S) :-
    format(S,
"crosswordsmith - a deterministic crossword grid toolkit~n~n\c
Lay out crossword grids, validate them against house-style rules, and export~n\c
them to standard interchange formats. Output is diffable and deterministic~n\c
by default; it builds grids, not clues.~n~n\c
Usage: crosswordsmith <verb> [options]~n~n\c
Verbs that build a grid - two ways in, chosen by what you already have:~n~n\c
~w~n\c
~w~n~n\c
Verbs that work on a grid - arrange and fill each produce a layout:~n~n\c
~w~n\c
~w~n~n\c
Run `crosswordsmith <verb> --help` for a verb's options.~n",
    % Verb lines are ~w atoms so their 4-space indent survives: an inline
    % `~n\c` continuation would otherwise swallow the next line's leading space.
    [ '    arrange   Have the words, need a grid?   Interlock them into one.',
      '    fill      Have the grid, need the words? Fill it from a dictionary.',
      '    lint      Validate a layout against a house-style rule profile.',
      '    export    Convert a layout to a shareable format (ipuz or Exolve).' ]).


% --- the `arrange` verb -----------------------------------------------------

arrange_opts_spec(
    [ [opt(help),        type(boolean), default(false),
       shortflags([h]), longflags([help]),       help('show these arrange options')],
      [opt(strict),      type(boolean), default(false),
       longflags([strict]),                       help('fail unless every word is placed (the default)')],
      [opt(best_effort), type(boolean), default(false),
       longflags(['best-effort']),                help('place a maximal subset; report dropped words')],
      [opt(size),        type(integer), default(-1), meta('N'),
       longflags([size]),                         help('exact grid side: an N x N grid (default 15). Mutually exclusive with --max-size')],
      [opt(max_size),    type(integer), default(-1), meta('N'),
       longflags(['max-size']),                   help('build up to N x N, then crop to the tight enclosing square (<= N). Mutually exclusive with --size')],
      [opt(fragment),    type(atom),    default(''), meta('FILE'),
       longflags([fragment]),                     help('seed from a partial-layout fragment (JSON): the canonical {gridLength, words} object (gridLength sets N) or a thin [{answer,row,col,dir}] list (framed by --size/--max-size, default 15)')],
      [opt(candidates),  type(integer), default(0), meta('K'),
       longflags([candidates]),                   help('emit up to K diverse layouts (a JSON array) instead of one')],
      [opt(enumerate),   type(boolean), default(false),
       longflags([enumerate]),                    help('count every feasible full placement instead of emitting a layout')],
      [opt(check_target), type(integer), default(-1), meta('N'),
       longflags(['check-target']),               help('lower the per-word checking target to <= N (default ceil(L/2); loosen it when strict placement is otherwise unreachable)')],
      [opt(seed),        type(integer), default(-1), meta('N'),
       longflags([seed]),                         help('perturb the strict search with RNG seed N (>=0) for a reproducible pseudo-random layout; omit for the deterministic layout')],
      [opt(shuffle),     type(boolean), default(false),
       longflags([shuffle]),                      help('perturb the strict search with a FRESH random seed each run (a different layout every time; --verbose prints the seed to reproduce it). Mutually exclusive with --seed')],
      [opt(verbose),     type(boolean), default(false),
       longflags([verbose]),                      help('report the success summary (grid, placed, reward) on stderr; warnings and failures print regardless')],
      [opt(input),       type(atom),    default(''), meta('FILE'),
       longflags([input]),                        help('REQUIRED: the word/clue set (.json or .pl)')],
      [opt(out),         type(atom),    default(''), meta('FILE'),
       longflags([out]),                          help('write output to FILE instead of stdout')]
    ]).

arrange_cli(Args) :-
    arrange_opts_spec(Spec),
    catch(opt_parse(Spec, Args, Opts, Positional),
          _Err,
          (cli_error('could not parse options'), fail)),
    (   memberchk(help(true), Opts)
    ->  arrange_usage(user_output)
    ;   Positional \== []
    ->  cli_error('unexpected argument(s) ~w (every input is a flag; pass the grid via --size)'-[Positional])
    ;   arrange_dispatch(Opts)
    ).

arrange_usage(S) :-
    arrange_opts_spec(Spec),
    opt_help(Spec, Help),
    format(S, "Usage: crosswordsmith arrange --input <file> [options]~n~n~w", [Help]).

arrange_dispatch(Opts) :-
    memberchk(input(InputFile), Opts),
    ( InputFile \== '' -> true ; cli_error('missing required --input FILE') ),
    drop_contract(Opts, Drop),
    memberchk(size(SizeOpt), Opts),
    memberchk(max_size(MaxSizeOpt), Opts),
    validate_size_flag('--size', SizeOpt),
    validate_size_flag('--max-size', MaxSizeOpt),
    resolve_size_flags(SizeOpt, MaxSizeOpt, SizeNum, Mode),
    memberchk(fragment(FragFile), Opts),
    memberchk(candidates(K), Opts),
    memberchk(enumerate(Enum), Opts),
    memberchk(out(OutFile), Opts),
    memberchk(check_target(CT), Opts),
    validate_check_target(CT),
    set_check_target(CT),
    memberchk(seed(SeedOpt), Opts),
    memberchk(shuffle(Shuffle), Opts),
    validate_seed(SeedOpt),
    seed_mode(Shuffle, SeedOpt, SeedMode),
    guard_seed_combos(SeedMode, Drop, Enum, K),
    memberchk(verbose(Verbose), Opts),
    set_verbose(Verbose),
    apply_seed_mode(SeedMode),
    load_clues(InputFile, Words),
    arrange_action(Enum, K, FragFile, Words, SizeNum, Drop, Mode, OutFile).

% --strict / --best-effort are mutually exclusive; strict is the default.
drop_contract(Opts, Drop) :-
    memberchk(strict(S), Opts), memberchk(best_effort(B), Opts),
    (   S == true, B == true
    ->  cli_error('--strict and --best-effort are mutually exclusive')
    ;   B == true -> Drop = best_effort
    ;   Drop = strict
    ).

% --check-target: a global ceiling on the per-word checking target (design-spec
% §7.2 reachability escape hatch). The CLI only validates the flag; the state
% lives in crosswordsmith_arrange, behind its exported set_check_target/1
% (-1 = the "not given" sentinel, clears any override; N>=1 lowers each word's
% target to min(ceil(L/2), N)).
validate_check_target(-1) :- !.
validate_check_target(N) :- integer(N), N >= 1, !.
validate_check_target(N) :- cli_error('--check-target must be a positive integer (got ~w)'-[N]).

% --seed / --shuffle perturb the strict mrv_inc search (design note: a fully
% deterministic default alongside an opt-in pseudo-random path; the seed never
% touches the deterministic flow). --seed N (N>=0) is a REPRODUCIBLE seed;
% --shuffle draws a FRESH one each run. -1 is the --seed "not given" sentinel.
% The state lives behind core's exported set_search_seed/1 & set_shuffle_seed/1.
validate_seed(-1) :- !.
validate_seed(N) :- integer(N), N >= 0, !.
validate_seed(N) :- cli_error('--seed must be a non-negative integer (got ~w)'-[N]).

% Resolve --seed / --shuffle into one perturbation mode. They are mutually
% exclusive: you either fix the seed or randomise it, never both.
%   none | fixed(N) | shuffle
seed_mode(true, -1, shuffle) :- !.
seed_mode(true, _N, _)       :- !, cli_error('--seed and --shuffle are mutually exclusive').
seed_mode(false, -1, none)   :- !.
seed_mode(false, N,  fixed(N)).

% Perturbation rides the strict single-layout search only. The greedy paths
% (--best-effort, --candidates) and --enumerate never reach the perturbed seam,
% so combining them would silently do nothing — reject it up front with a clear
% message instead. Strict, with or without --fragment, is fine.
guard_seed_combos(none, _Drop, _Enum, _K) :- !.
guard_seed_combos(_Mode, best_effort, _Enum, _K) :- !,
    cli_error('--seed/--shuffle perturb the strict search only; not compatible with --best-effort').
guard_seed_combos(_Mode, _Drop, true, _K) :- !,
    cli_error('--seed/--shuffle cannot be combined with --enumerate (enumeration counts placements; branch order is irrelevant)').
guard_seed_combos(_Mode, _Drop, _Enum, K) :- K > 0, !,
    cli_error('--seed/--shuffle cannot be combined with --candidates (candidates already emit diverse layouts deterministically)').
guard_seed_combos(_Mode, _Drop, _Enum, _K).

% Install the resolved perturbation. `shuffle` picks a fresh, recoverable seed
% and (only under --verbose, honouring the quiet-success contract) reports it so
% a liked layout can be reproduced with --seed N.
apply_seed_mode(none)     :- set_search_seed(-1).
apply_seed_mode(fixed(N)) :- set_search_seed(N).
apply_seed_mode(shuffle)  :-
    set_shuffle_seed(N),
    verbose_report("arrange: shuffle seed ~w (reproduce with --seed ~w)~n", [N, N]).

% --size / --max-size: two mutually-exclusive ways to frame the output grid.
%   --size N     : an exact N x N grid (SizeMode = fixed).
%   --max-size M : build up to M x M, crop to the tight enclosing square (max).
%   neither      : a standard 15 x 15 fixed grid.
% -1 is each flag's "not given" sentinel; positivity is validated here.
validate_size_flag(_Name, -1) :- !.
validate_size_flag(_Name, N) :- integer(N), N > 0, !.
validate_size_flag(Name, N) :- cli_error('~w must be a positive integer (got ~w)'-[Name, N]).

% Fold the two flags into the (SizeNum, Mode) pair the rest of arrange consumes.
% SizeNum keeps the -1 "not given" sentinel so the fragment path can fall back
% to the fragment's own gridLength (resolve_size/2); a bare invocation resolves
% to 15 x 15 fixed.
resolve_size_flags(-1, -1, -1, fixed) :- !.
resolve_size_flags(N,  -1, N,  fixed) :- !.
resolve_size_flags(-1, M,  M,  max)   :- !.
resolve_size_flags(_N, _M, _,  _)     :- cli_error('--size and --max-size are mutually exclusive').

% Resolve the size number: -1 sentinel means "not given". For a fragment the
% fragment's gridLength provides N; otherwise default to 15.
resolve_size(-1, 15) :- !.
resolve_size(N, N) :- integer(N), N > 0, !.
resolve_size(N, _) :- cli_error('--size must be a positive integer (got ~w)'-[N]).

% Mode selection (mutually-exclusive feature flags), each with a clear error on
% an unsupported combination (AC-CLI-2: documented behaviour or a usage hint).
arrange_action(true, K, Frag, _W, _S, _D, _M, _O) :-
    ( K > 0 ; Frag \== '' ), !,
    cli_error('--enumerate cannot be combined with --candidates or --fragment').
arrange_action(true, _K, _Frag, Words, SizeOpt, _Drop, _Mode, OutFile) :- !,
    resolve_size(SizeOpt, GridLen),
    with_output(OutFile, arrange_enumerate_solve(Words, GridLen)).
arrange_action(false, K, Frag, _W, _S, _D, _M, _O) :-
    K > 0, Frag \== '', !,
    cli_error('--candidates cannot be combined with --fragment (v1)').
arrange_action(false, _K, Frag, Words, SizeOpt, Drop, Mode, OutFile) :-
    Frag \== '', !,
    % SizeFrame doubles as load_fragment's SizeCtx: it frames a thin
    % fragment's desugar (none -> the default 15), and reconcile then
    % cross-checks it against the returned gridLength (a no-op for thin,
    % which desugars AT the frame; the real guard for canonical).
    ( SizeOpt == -1 -> SizeFrame = none ; SizeFrame = SizeOpt ),
    load_fragment(Frag, SizeFrame, FragGridLen, Frags),
    reconcile_fragment_size(FragGridLen, SizeFrame, GridLen),
    with_output(OutFile, arrange_fragment_solve(Words, Frags, GridLen, Drop, Mode)).
arrange_action(false, K, _Frag, Words, SizeOpt, Drop, Mode, OutFile) :-
    K > 0, !,
    resolve_size(SizeOpt, GridLen),
    with_output(OutFile, arrange_candidates_solve(Words, GridLen, Drop, Mode, K)).
arrange_action(false, _K, _Frag, Words, SizeOpt, Drop, Mode, OutFile) :-
    resolve_size(SizeOpt, GridLen),
    with_output(OutFile, arrange_solve(Words, GridLen, Drop, Mode)).

% Print a usage error under the given verb prefix on stderr and fail (-> exit 1).
% Accepts a bare message or a Format-Args pair. cli_error/1 and lint_err/1 are the
% per-verb wrappers.
fail_with(Prefix, Fmt-Args) :- !,
    format(user_error, "~w: ", [Prefix]),
    format(user_error, Fmt, Args),
    nl(user_error), fail.
fail_with(Prefix, Msg) :-
    format(user_error, "~w: ~w~n", [Prefix, Msg]), fail.

cli_error(X)  :- fail_with('crosswordsmith arrange', X).
lint_err(X)   :- fail_with('crosswordsmith lint', X).
export_err(X) :- fail_with('crosswordsmith export', X).
fill_err(X)   :- fail_with('crosswordsmith fill', X).


% --- the `lint` verb (design-spec §8.1) -------------------------------------

lint_opts_spec(
    [ [opt(help),            type(boolean), default(false),
       shortflags([h]), longflags([help]),   help('show these lint options')],
      [opt(profile),         type(atom),    default(''), meta('NAME'),
       longflags([profile]),                 help('rule/severity profile: toc, blocked-uk, american, barred-ximenean')],
      [opt(allow_asymmetry), type(boolean), default(false),
       longflags(['allow-asymmetry']),       help('symmetry never hard-FAILs (downgrade to WARN)')],
      [opt(out),             type(atom),    default(''), meta('FILE'),
       longflags([out]),                     help('write the report to FILE instead of stdout')]
    ]).

lint_cli(Args) :-
    lint_opts_spec(Spec),
    catch(opt_parse(Spec, Args, Opts, Positional),
          _Err,
          (lint_err('could not parse options'), fail)),
    (   memberchk(help(true), Opts)
    ->  lint_usage(user_output)
    ;   lint_dispatch(Opts, Positional)
    ).

lint_usage(S) :-
    lint_opts_spec(Spec),
    opt_help(Spec, Help),
    format(S,
"Usage: crosswordsmith lint --profile <name> [--allow-asymmetry] <layout.json>~n~n\c
Validates a canonical layout (what `arrange` emits). Profiles: toc (advisory),~n\c
blocked-uk, american, barred-ximenean (the Ximenean per-length unch band). Exit~n\c
is non-zero only when a FAIL-severity rule trips.~n~n~w", [Help]).

lint_dispatch(Opts, Positional) :-
    (   Positional = [LayoutFile]
    ->  true
    ;   Positional == []
    ->  lint_err('needs a layout file: crosswordsmith lint --profile <name> <layout.json>')
    ;   lint_err('takes exactly one layout file (got ~w)'-[Positional])
    ),
    memberchk(profile(P0), Opts),
    resolve_lint_profile(P0, Profile),
    memberchk(allow_asymmetry(Allow), Opts),
    memberchk(out(OutFile), Opts),
    % lint_solve always succeeds (it emits the report regardless of verdict and
    % binds Verdict), so --out always captures the report; the exit code is the
    % verdict (AC-LINT-2): FAIL -> fail -> exit non-zero.
    with_output(OutFile, lint_solve(LayoutFile, Profile, Allow, Verdict)),
    ( Verdict == 'FAIL' -> fail ; true ).

resolve_lint_profile('', _) :- !,
    lint_err('requires --profile <name> (toc, blocked-uk, american, barred-ximenean)').
resolve_lint_profile(P, P) :- lint_known_profile(P), !.
resolve_lint_profile(P, _) :-
    lint_err('unknown profile ~w; choose toc, blocked-uk, american, or barred-ximenean'-[P]).


% --- the `export` verb (design-spec §8.2) -----------------------------------

export_opts_spec(
    [ [opt(help), type(boolean), default(false),
       shortflags([h]), longflags([help]),  help('show these export options')],
      [opt(to),   type(atom),    default(''), meta('FORMAT'),
       longflags([to]),                      help('target format: ipuz or exolve')],
      [opt(out),  type(atom),    default(''), meta('FILE'),
       longflags([out]),                     help('write to FILE instead of stdout')]
    ]).

export_cli(Args) :-
    export_opts_spec(Spec),
    catch(opt_parse(Spec, Args, Opts, Positional),
          _Err,
          (export_err('could not parse options'), fail)),
    (   memberchk(help(true), Opts)
    ->  export_usage(user_output)
    ;   export_dispatch(Opts, Positional)
    ).

export_usage(S) :-
    export_opts_spec(Spec),
    opt_help(Spec, Help),
    format(S,
"Usage: crosswordsmith export --to ipuz|exolve <layout.json> [--out FILE]~n~n\c
Transforms a canonical layout (what `arrange` emits). ipuz -> ipuz v2 JSON~n\c
(onward to .puz/.jpz/PDF via off-the-shelf kotwords); exolve -> Exolve plain~n\c
text (round-trips to Exet).~n~n~w", [Help]).

export_dispatch(Opts, Positional) :-
    (   Positional = [LayoutFile]
    ->  true
    ;   Positional == []
    ->  export_err('needs a layout file: crosswordsmith export --to <fmt> <layout.json>')
    ;   export_err('takes exactly one layout file (got ~w)'-[Positional])
    ),
    memberchk(to(F0), Opts),
    resolve_export_format(F0, Format),
    memberchk(out(OutFile), Opts),
    with_output(OutFile, export_solve(LayoutFile, Format)).

resolve_export_format('', _) :- !,
    export_err('requires --to ipuz|exolve').
resolve_export_format(ipuz, ipuz) :- !.
resolve_export_format(exolve, exolve) :- !.
resolve_export_format(F, _) :-
    export_err('unknown format ~w; choose ipuz or exolve'-[F]).


% --- the `fill` verb (design-spec §8.4) -------------------------------------

fill_opts_spec(
    [ [opt(help),  type(boolean), default(false),
       shortflags([h]), longflags([help]),  help('show these fill options')],
      [opt(grid),  type(atom),    default(''), meta('FILE'),
       longflags([grid]),                    help('REQUIRED: the grid template (a black-square mask; stock grids in grids/)')],
      [opt(seeds), type(atom),    default(''), meta('FILE'),
       longflags([seeds]),                   help('seed words to pin (a partial-layout fragment, JSON: the canonical {gridLength, words} object or a thin [{answer,row,col,dir}] list framed by the grid itself)')],
      [opt(dict),  type(atom),    default(''), meta('FILE'),
       longflags([dict]),                    help('word list, one per line (default: a small bundled sample; real fills: --dict UKACD18)')],
      [opt(save_index), type(atom), default(''), meta('FILE'),
       longflags(['save-index']),            help('build a reusable index artifact from --dict, write it to FILE, and exit (no grid/fill; skips the parse+index tax on later fills)')],
      [opt(masks), type(boolean), default(false),
       longflags([masks]),                   help('with --save-index: also embed bitset counting masks (faster fill phase for search-heavy grids / WASM; ~32% bigger artifact that loads slower - skip for quick interactive fills)')],
      [opt(index), type(atom),    default(''), meta('FILE'),
       longflags([index]),                   help('fill using a prebuilt index artifact (from --save-index) instead of parsing --dict; also pass --dict to verify the artifact matches that dictionary')],
      [opt(verbose), type(boolean), default(false),
       longflags([verbose]),                 help('report the success summary (grid, filled slots) on stderr; failures print regardless')],
      [opt(out),   type(atom),    default(''), meta('FILE'),
       longflags([out]),                     help('write output to FILE instead of stdout')]
    ]).

fill_cli(Args) :-
    fill_opts_spec(Spec),
    catch(opt_parse(Spec, Args, Opts, Positional),
          _Err,
          (fill_err('could not parse options'), fail)),
    (   memberchk(help(true), Opts)
    ->  fill_usage(user_output)
    ;   fill_dispatch(Opts, Positional)
    ).

fill_usage(S) :-
    fill_opts_spec(Spec),
    opt_help(Spec, Help),
    format(S,
"Usage: crosswordsmith fill --grid <mask> [--seeds <frag>] [--dict <words>]~n~n\c
Fills a legal blocked grid from a word list, seeds pinned. Output is a canonical~n\c
layout (composes with lint/export). Exit is non-zero, naming the unfillable~n\c
slot(s), when no complete fill exists.~n~n~w", [Help]).

% Three modes, chosen by --save-index / --index (mutually exclusive), following
% arrange's mutually-exclusive-flag house pattern:
%   --save-index FILE  : BUILD an index artifact from --dict, write FILE, exit
%                        (no --grid, no fill).
%   --index FILE       : CONSUME a prebuilt artifact instead of parsing --dict
%                        (--grid required; --dict, if given, verifies the hash).
%   (neither)          : the raw text-dict path, byte-for-byte unchanged.
fill_dispatch(Opts, Positional) :-
    ( Positional == [] -> true ; fill_err('takes only flags (got ~w)'-[Positional]) ),
    memberchk(save_index(SaveIdx), Opts),
    memberchk(index(UseIdx), Opts),
    memberchk(verbose(Verbose), Opts),
    set_verbose(Verbose),
    ( SaveIdx \== '', UseIdx \== ''
    ->  fill_err('--save-index and --index are mutually exclusive (build the artifact, then fill with it)')
    ;   SaveIdx \== ''
    ->  fill_build_index(SaveIdx, Opts)
    ;   fill_run_dispatch(UseIdx, Opts) ).

% BUILD mode: no grid, no fill. Serialize the index built from --dict (or the
% bundled sample) to the artifact file. --out/--seeds/--grid are ignored here.
% --masks opts into embedding the F-H2 bitset counting masks (fill-phase wall
% win for search-heavy grids / WASM at a ~32% artifact-size + load-wall cost;
% the default artifact stays small and loads fast).
fill_build_index(SaveIdx, Opts) :-
    memberchk(dict(Dict0), Opts), ( Dict0 == '' -> default_dict(Dict) ; Dict = Dict0 ),
    memberchk(masks(WithMasks), Opts),
    fill_save_index(Dict, SaveIdx, [masks(WithMasks)]),
    verbose_report("fill: wrote index artifact ~w from ~w~n", [SaveIdx, Dict]).

% FILL mode (raw or artifact-consuming): --grid required.
fill_run_dispatch(UseIdx, Opts) :-
    memberchk(grid(Grid), Opts),
    ( Grid \== '' -> true ; fill_err('requires --grid FILE (a stock-grid mask)') ),
    memberchk(seeds(Seeds0), Opts), ( Seeds0 == '' -> Seeds = none ; Seeds = Seeds0 ),
    memberchk(dict(Dict0), Opts),
    memberchk(out(OutFile), Opts),
    (   UseIdx \== ''
    ->  % CONSUME: --dict, if explicitly given, verifies the artifact's hash.
        ( Dict0 == '' -> DictCheck = none ; DictCheck = Dict0 ),
        with_output(OutFile, fill_solve_index(Grid, Seeds, UseIdx, DictCheck, fixed))
    ;   ( Dict0 == '' -> default_dict(Dict) ; Dict = Dict0 ),
        with_output(OutFile, fill_solve(Grid, Seeds, Dict, fixed)) ).

% The default dictionary is the small bundled sample, resolved relative to the
% script directory (real fills pass --dict <UKACD18>).
default_dict(Dict) :-
    ( script_directory(Dir) -> true ; Dir = '.' ),
    directory_file_path(Dir, 'fixtures/wordlist_sample.txt', Dict).


:- initialization(main, main).
