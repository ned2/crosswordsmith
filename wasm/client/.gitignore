# Built WASM artifacts + qlf — reproducible from the build (see README), not source.
# swipl-web.* also covers the content-hashed copies (swipl-web.<sha256:12>.js …)
# stamped by wasm/build/stamp-manifest.sh, as *.qlf does for the hashed qlf.
swipl-web.*
*.qlf
build-manifest.json
# copied in by stamp-manifest.sh so the deployable bundle carries its licence
# notice; the tracked original lives at wasm/THIRD_PARTY_NOTICES.md
THIRD_PARTY_NOTICES.md
